# Server
PORT=4000

# Database (path relative to backend folder inside container)
DB_PATH=./data/ai-ideas.db

# Product Board API (optional)
PRODUCT_BOARD_API_KEY=
PRODUCT_BOARD_BASE_URL=https://api.productboard.com

# OpenAI (required for competitor analysis & use case generation)
OPENAI_API_KEY=

# Google APIs (optional – for Customer Insights & Competitor Analysis docs)
# For creating real Google Docs: set GOOGLE_APPLICATION_CREDENTIALS to the path of your service account JSON key file.
# (Create a service account in Google Cloud Console → IAM → Service accounts → Create key → JSON. Enable Drive API & Docs API.)
GOOGLE_APPLICATION_CREDENTIALS=
# Optional: API key clears "stub" message; OAuth client ID/secret/redirect are for user sign-in flow.
GOOGLE_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Google Sheet (feature list source)
GOOGLE_SHEET_ID=
GOOGLE_SHEET_GID=

# Competitors list for analysis (comma-separated)
COMPETITORS=BambooHR, Workday, HiBOB, SAP SuccessFactors, ADP

# Scoring weights: tier name -> weight (JSON)
SCORE_TIER_WEIGHTS={"enterprise":3,"professional":2,"starter":1}
